# Versioning: tags are NOT set by npm, but manually after the merge into `main`
# directly on the merge commit (best practice for our GitLab-Flow model,
# release = state on `main`).
#
# NOTE: `git-tag-version=false` disables npm's ENTIRE git step in `npm version`
# — both commit AND tag. So `npm version <patch|…>` on its own only bumps
# package.json/package-lock.json and does NOT commit.
#
# The bump commit (still without a tag) is created by the `version` lifecycle
# script in package.json. Use the `release:*` scripts (e.g. `npm run
# release:patch`) to bump and commit in one step.
git-tag-version=false

# "v" prefix for tags we set manually (convention on main).
tag-version-prefix=v
